# Leave empty in development (Vite proxy handles /api → localhost:3001)
# Set to your Railway backend URL in production:
# VITE_API_URL=https://gathering-api.up.railway.app
VITE_API_URL=

# Firebase Phone Auth (public web config — Firebase Console → Project settings →
# your Web app → SDK setup and configuration). If unset, login falls back to Google.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
