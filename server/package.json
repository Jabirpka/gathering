{
  "name": "gathering-server",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "./node_modules/.bin/prisma db execute --file ./prisma/premigrate.sql --schema ./prisma/schema.prisma && ./node_modules/.bin/prisma db push --accept-data-loss && node dist/index.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.10.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-session": "^1.18.0",
    "express-validator": "^7.0.1",
    "firebase-admin": "^14.0.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.2.0",
    "nanoid": "^3.3.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "prisma": "5.10.0",
    "redis": "^4.6.13",
    "socket.io": "^4.7.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.11.30",
    "@types/passport": "^1.0.16",
    "@types/passport-google-oauth20": "^2.0.14",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.2"
  }
}
