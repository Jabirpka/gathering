generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  googleId      String?        @unique
  email         String?        @unique
  phone         String?        @unique
  name          String
  nickname      String?
  avatar        String?
  // Wide header image shown at the top of the profile (data URL, like avatar)
  banner        String?
  // Profile / onboarding fields (v2)
  username      String?        @unique
  dateOfBirth   String?
  bio           String?
  interests     String[]       @default([])
  favoriteSong  String?
  favoriteMovie String?
  city          String?
  // "About you" profile prompts (free text)
  whoAreYou     String?
  whatCanYouDo  String?
  trust         String?
  lookingFor    String?
  wantToMeet    String?
  // Extended profile (education, career, skills, lifestyle, socials, favorites,
  // emergency, etc) - one JSON blob keyed by field, shaped by the client's
  // profile schema config. The "emergency" key is private (stripped from the
  // public profile endpoint).
  profileExtra  Json?
  // Whether the user finished the "set up profile" onboarding. Defaults true so
  // existing accounts are unaffected; new signups are created with false.
  onboarded     Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  groups        GroupMember[]
  createdGroups Group[]        @relation("GroupCreator")
  messages      Message[]
  pokesReceived Poke[]         @relation("PokeReceiver")
  pokesSent     Poke[]         @relation("PokeSender")
  pushTokens    PushToken[]
  dmThreadsA    DmThread[]     @relation("DmUserA")
  dmThreadsB    DmThread[]     @relation("DmUserB")
  statuses      Status[]
  reactions     MessageReaction[]
  pollVotes     PollVote[]
  eventRsvps    EventRsvp[]
  quizAnswers   QuizAnswer[]
}

// WhatsApp-style status/story: text or image, auto-expires after 24h.
// Visible to anyone who shares an approved group with the author.
model Status {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kind      String   @default("TEXT") // TEXT | IMAGE
  content   String   // text body, or image data URL
  bg        String?  // background color for text statuses
  createdAt DateTime @default(now())
  expiresAt DateTime
}

// 1:1 direct-message conversation. The pair is stored in canonical order
// (userAId < userBId) so each pair has exactly one thread. Per-side lastRead
// timestamps drive unread counts, mirroring GroupMember.lastReadAt.
model DmThread {
  id         String    @id @default(cuid())
  userAId    String
  userBId    String
  userA      User      @relation("DmUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB      User      @relation("DmUserB", fields: [userBId], references: [id], onDelete: Cascade)
  lastReadA  DateTime?
  lastReadB  DateTime?
  // "Delete chat" (WhatsApp-style, per side): messages up to this point are
  // hidden for that user; the other side keeps their copy.
  clearedAtA DateTime?
  clearedAtB DateTime?
  messages   Message[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@unique([userAId, userBId])
}

// One reaction per user per message (tap again to remove / change).
model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
}

model PushToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   @default("android")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model Poke {
  id         String   @id @default(cuid())
  senderId   String
  receiverId String
  sender     User     @relation("PokeSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiver   User     @relation("PokeReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
}

model Group {
  id              String           @id @default(cuid())
  name            String
  code            String           @unique
  description     String?
  avatar          String?
  category        String?
  isPublic        Boolean          @default(false)
  requireApproval Boolean          @default(true)
  creatorId       String
  creator         User             @relation("GroupCreator", fields: [creatorId], references: [id])
  members         GroupMember[]
  messages        Message[]
  rooms           Room[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model GroupMember {
  id       String       @id @default(cuid())
  userId   String
  groupId  String
  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  group    Group        @relation(fields: [groupId], references: [id], onDelete: Cascade)
  role       Role         @default(MEMBER)
  status     MemberStatus @default(PENDING)
  joinedAt   DateTime     @default(now())
  lastReadAt DateTime?

  @@unique([userId, groupId])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum MemberStatus {
  PENDING
  APPROVED
  BANNED
}

model Room {
  id        String   @id @default(cuid())
  name      String
  type      RoomType @default(VIDEO_CALL)
  groupId   String
  group     Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  isActive  Boolean  @default(true)
  messages  Message[]
  createdAt DateTime @default(now())
}

enum RoomType {
  VIDEO_CALL
  AUDIO_CALL
}

model Message {
  id        String    @id @default(cuid())
  content   String
  // TEXT (plain content) or VOICE (content is an audio data URL)
  kind      String    @default("TEXT")
  // Voice note length in seconds
  duration  Int?
  userId    String
  groupId   String?
  roomId    String?
  threadId  String?
  // Reply-to (quoted message). Kept when the original is deleted so the
  // quote can render a "deleted" placeholder.
  replyToId String?
  replyTo   Message?  @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[] @relation("MessageReplies")
  // Delete-for-everyone: content is blanked and this timestamp set.
  deletedAt DateTime?
  user      User      @relation(fields: [userId], references: [id])
  group     Group?    @relation(fields: [groupId], references: [id])
  room      Room?     @relation(fields: [roomId], references: [id])
  thread    DmThread? @relation(fields: [threadId], references: [id], onDelete: Cascade)
  reactions MessageReaction[]
  pollVotes PollVote[]
  eventRsvps EventRsvp[]
  quizAnswers QuizAnswer[]
  createdAt DateTime  @default(now())
}

// RSVP to an EVENT message (event details live in the message JSON content).
model EventRsvp {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  status    String   // GOING | MAYBE | NO
  plusGuest Boolean  @default(false)
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([messageId, userId])
}

// One user's answer to a QUIZ message. groupId + points are denormalized so the
// per-group leaderboard is a single cheap groupBy/sum.
model QuizAnswer {
  id          String   @id @default(cuid())
  messageId   String
  groupId     String
  userId      String
  optionIndex Int
  correct     Boolean
  points      Int      @default(0)
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([messageId, userId])
}

// A vote on a POLL message. The poll's question/options/settings live in the
// message's JSON `content`; each row here is one option a user picked (a user
// may pick several when the poll allows multiple answers).
model PollVote {
  id          String   @id @default(cuid())
  messageId   String
  userId      String
  optionIndex Int
  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([messageId, userId, optionIndex])
}

