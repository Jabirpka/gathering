# Server
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://gathering:gathering_secret@localhost:5432/gathering_db

# Redis
REDIS_URL=redis://localhost:6379

# Auth
SESSION_SECRET=change-this-in-production-32-chars-min
JWT_SECRET=change-this-in-production-32-chars-min

# Google OAuth (https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# LiveKit (self-hosted or https://livekit.io)
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret
LIVEKIT_WS_URL=ws://localhost:7880

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Firebase Admin (push notifications + phone-auth token verification).
# From Firebase Console → Project settings → Service accounts → Generate new
# private key. Use the SAME project as the client VITE_FIREBASE_* config.
# FIREBASE_PRIVATE_KEY: paste the PEM with literal \n for newlines, or the whole
# PEM base64-encoded as one line (recommended to avoid env-UI mangling).
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY=your_firebase_private_key
